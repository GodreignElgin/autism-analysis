# Autism Detection Platform - Environment Configuration
# Copy this file to .env and fill in your actual values

# Google Gemini AI API Key (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your-api-key-here

# Database Configuration
# DATABASE_URL=sqlite:///autism_detection.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/autism_detection

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
JWT_SECRET_KEY=your-secret-key-change-in-production

# File Upload Settings
MAX_CONTENT_LENGTH=52428800  # 50MB in bytes

# ML Model Path
MODEL_PATH=ml_model/autism_model.h5

# Optional tabular model for ensemble inference
TABULAR_MODEL_PATH=model/best_model.pkl

# Ensemble weights (weighted average)
IMAGE_MODEL_WEIGHT=0.7
TABULAR_MODEL_WEIGHT=0.3

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO
